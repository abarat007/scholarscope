# --- LLM ---------------------------------------------------------------
# Required from Phase 4 onward (structured extraction & synthesis).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# --- Postgres ----------------------------------------------------------
POSTGRES_HOST=localhost
# Host-published port (5433 avoids clashing with any local Postgres on 5432)
POSTGRES_PORT=5433
POSTGRES_USER=scholarscope
POSTGRES_PASSWORD=scholarscope
POSTGRES_DB=scholarscope

# --- OpenSearch --------------------------------------------------------
OPENSEARCH_URL=http://localhost:9200

# --- Redis -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Airflow -----------------------------------------------------------
AIRFLOW_URL=http://localhost:8080

# arXiv categories the daily DAG ingests (comma-separated). Default is CS-only,
# so cross-domain topics (e.g. "spatial omics" vs. "spatial reasoning") only
# have CS papers to retrieve from and can pull in same-keyword-different-field
# noise. Add q-bio categories to give biology-adjacent topics real matches —
# they use the same arXiv API/client already built, no new ingestion code:
#   q-bio.NC Neurons & Cognition   q-bio.GN Genomics
#   q-bio.QM Quantitative Methods  q-bio.CB Cell Behavior   q-bio.TO Tissues/Organs
# ARXIV_INGEST_CATEGORIES=cs.CL,cs.AI,cs.LG,q-bio.NC,q-bio.QM
#
# After changing this, restart airflow (`docker compose up -d airflow`) for
# the daily DAG, and/or run a one-shot backfill for the new categories, e.g.:
#   make backfill QUERY='cat:q-bio.NC' MAX=2000
#   make backfill QUERY='cat:q-bio.QM' MAX=2000
#   make reindex   # embed + index the newly ingested papers
ARXIV_INGEST_CATEGORIES=cs.CL,cs.AI,cs.LG

# --- Langfuse (self-hosted in compose) ----------------------------------
# Defaults below match the headless keys compose provisions; the UI is at
# http://localhost:3000 (login dev@scholarscope.local / scholarscope-dev).
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-scholarscope-local
LANGFUSE_SECRET_KEY=sk-lf-scholarscope-local
